---
import Layout from '../layouts/Page.astro';

// Easily add, remove, or edit your projects here
const projects = [
	
	{
		title: "👣 Whose 15-Minute City?",
		description: "The blog post version of my capstone masters project, an equity-focused GIS analysis of accessibility in my hometown of Chicago. Full paper's linked too!",
		link: "https://metroplanning.org/whose-15-minute-city-measuring-equity-of-access-in-chicago/"
	},
	{
		title: "📝 Carolina Angles",
		description: "My posts for the Carolina Planning Journal's blog written while in graduate school.",
		link: "https://carolinaangles.com/?s=%22by+doug+bright%22"
	},
	{
		title: "🗺️ Bright Over There",
		description: "Writing and photography from my personal travels.",
		link: "https://brightoverthere.tumblr.com/"
	}
];
const inprogress = [
	{
		title: "📍 SF Amenity Finder",
		description: "A mobile-first tool parsing 12,000+ municipal data points to find the closest public resource based on live GPS.",
		link: "/find"
	}
	
];
---

<Layout title="Home" description="Welcome to my portfolio" pubDate={new Date()}>
	<section class="hero">
		<h1>Hi, I'm Doug 👋</h1>
		<p class="bio">
			I’m a product manager and transportation planner focused on using design thinking to solve public problems.
			I like cities, nature, transportation, technology, design, food, baseball, and plenty more.
		</p>
	</section>

	<hr />

	<section class="projects-section">
		<h2>✅ Things I've made</h2>
		
		<div class="project-grid">
			{projects.map((project) => (
				<div class="project-card">
					<h3>{project.title}</h3>
					<p>{project.description}</p>
					{project.link !== "#" ? (
						<a href={project.link} class="project-link">Check it out →</a>
					) : (
						<span class="project-link disabled">Repo private / Coming soon</span>
					)}
				</div>
			))}
		</div>
		<h2>🚧 Things I'm making (in progress) </h2>
		
		<div class="project-grid">
			{inprogress.map((inprogress) => (
				<div class="project-card">
					<h3>{inprogress.title}</h3>
					<p>{inprogress.description}</p>
					{inprogress.link !== "#" ? (
						<a href={inprogress.link} class="project-link">Check it out →</a>
					) : (
						<span class="project-link disabled">Repo private / Coming soon</span>
					)}
				</div>
			))}
		</div>
	</section>
</Layout>

<style>
	.hero { padding: 2rem 0 1rem; }
	h1 { font-size: 2.5rem; margin-bottom: 1rem; }
	.bio { font-size: 1.2rem; line-height: 1.6; color: #444; max-width: 650px; }
	
	hr { border: 0; border-top: 1px solid #eee; margin: 3rem 0; }
	
	.projects-section { margin-bottom: 4rem; }
	.section-subtitle { color: #666; margin-bottom: 2rem; }
	
	/* Layout grid: 1 column on mobile, 2 columns on tablet/desktop */
	.project-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 20px;
	}
	
	.project-card {
		background: #fdfdfd;
		padding: 1.5rem;
		border-radius: 12px;
		border: 1px solid #e5e5e5;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		transition: transform 0.2s ease, border-color 0.2s ease;
	}
	
	.project-card:hover {
		transform: translateY(-2px);
		border-color: #999;
	}
	
	.project-card h3 { margin-top: 0; font-size: 1.3rem; margin-bottom: 0.5rem; }
	.project-card p { font-size: 1rem; color: #555; line-height: 1.5; margin-bottom: 1.5rem; }
	
	.project-link {
		font-weight: 600;
		color: #000;
		text-decoration: none;
		font-size: 0.95rem;
		margin-top: auto;
	}
	.project-link:hover { text-decoration: underline; }
	.project-link.disabled { color: #999; font-weight: normal; }
	/* SOCIAL FOOTER styles */
	.social-footer {
		text-align: center;
		padding: 2rem 0;
		color: #666;
	}

	.social-footer p {
		font-size: 0.95rem;
		margin-bottom: 0.75rem;
	}

	.social-links {
		display: flex;
		justify-content: center;
		gap: 20px;
	}

	.social-links a {
		color: #444; /* Dark gray icons */
		transition: color 0.15s ease;
		display: inline-block;
	}

	.social-links a:hover {
		color: #000; /* Pure black on hover */
	}

	.icon {
		width: 40px;
		height: 40px;
		fill: currentColor; /* Forces SVG paths to show up using the link color */
		display: block;
	}
</style>

<hr />

<footer class="social-footer">
	<p>Find me on:</p>
	<div class="social-links">
		<a href="https://linkedin.com/in/doug-bright" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
